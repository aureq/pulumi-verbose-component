{
  "compilerOptions": {
      "strict": true,
      "outDir": "bin",
      "target": "ES2022",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "sourceMap": true,
      "experimentalDecorators": true,
      "pretty": true,
      "noFallthroughCasesInSwitch": true,
      "noImplicitReturns": true,
      "forceConsistentCasingInFileNames": true
  },
  "files": [
      "index.ts",
      "verbose.ts"
    ]
}